# ─── Auth (Clerk) ─────────────────────────────────────────────
# Share with theautonomousorg + autonomous-memory for SSO across products
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME
CLERK_SECRET_KEY=sk_live_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/vault
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/vault

# ─── Postgres (Supabase) ──────────────────────────────────────
# Use the same Supabase project as theautonomous.org; new schema "vault"
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# ─── At-rest encryption (V1: shared key, V2: per-user passphrase) ────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_ME_WITH_64_HEX_CHARS

# ─── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ─── Gmail OAuth ──────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Required scope: https://www.googleapis.com/auth/gmail.readonly
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=https://keys.theautonomous.org/api/gmail/callback

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_ADDRESS=Vault <vault@theautonomous.org>

# ─── Revoke adapters (V1: Anthropic + Resend confirmed; OpenAI/Apollo V1.1) ────
# Each user supplies their own service keys via /vault/add — we don't store ours

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://keys.theautonomous.org
NEXT_PUBLIC_APP_NAME=Vault

# ─── Feature flags ────────────────────────────────────────────
USE_AUTH=true
ENABLE_GMAIL_SYNC=true
ENABLE_KILL_ANTHROPIC=true
ENABLE_KILL_RESEND=true
ENABLE_KILL_OPENAI=false
ENABLE_KILL_APOLLO=false
